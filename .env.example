# 복사해서 .env 로 사용 (커밋 금지). CI는 GH Secrets 사용.
ANTHROPIC_API_KEY=sk-ant-...
NOTION_API_KEY=ntn_...
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 선택: data source id 직접 지정(다중 소스 DB일 때). 미설정 시 DB에서 자동 해석
# NOTION_DATA_SOURCE_ID=
# 선택: 모델 오버라이드 (기본 claude-sonnet-4-6)
# DR_MODEL=claude-sonnet-4-6
# 선택: 폴백 모델 (기본 claude-haiku-4-5) — 기본 모델 실패 시 승계
# DR_MODEL_FALLBACK=claude-haiku-4-5
# 선택(P4.5): Slack Incoming Webhook — 설정 시 질문 push 활성, 미설정 시 자동 스킵
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
